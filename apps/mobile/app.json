      "backgroundColor": "#000000",
      "barStyle": "light-content"
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "apiBaseUrl": "http://192.168.1.135:8080",
      "eas": {
        "projectId": "03a58767-bec8-48f9-a817-2bfb3e910079"
      }
    }
  }
