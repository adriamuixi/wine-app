{
  "expo": {
    "name": "Wine App",
    "slug": "wine-app-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wineapp.mobile"
    },
    "android": {
      "package": "com.wineapp.mobile"
    },
    "androidStatusBar": {
      "backgroundColor": "#4d192a",
